body { background: #0d0d0d; color: #ff8c42; font-family: sans-serif; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
.container { width: 90%; max-width: 400px; padding: 20px; border: 1px solid #444; border-radius: 20px; text-align: center; background: rgba(20, 20, 20, 0.8); }
.input-group { display: flex; gap: 5px; margin: 15px 0; }
input { flex: 1; padding: 10px; border-radius: 5px; border: 1px solid #ff8c42; background: #000; color: #fff; }
.paste-btn { padding: 10px; cursor: pointer; border: 1px solid #ff8c42; background: transparent; color: #ff8c42; }
.download-btn { width: 100%; padding: 15px; margin: 20px 0; background: #444; color: #ccc; border: none; border-radius: 10px; cursor: pointer; }
.circle { width: 100px; height: 100px; border: 5px solid #333; border-top: 5px solid #ff8c42; border-radius: 50%; margin: 20px auto; animation: spin 2s linear infinite; display: none; }
@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
