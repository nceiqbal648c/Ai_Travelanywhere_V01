body { 
    background: #000; 
    color: #00d4ff; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
    height: 100vh; 
    margin: 0; 
    font-family: monospace; 
}

.main-container { 
    text-align: center; 
    width: 300px; 
    border: 1px solid #00d4ff; 
    padding: 20px; 
}

input { 
    width: 100%; 
    background: #111; 
    border: 1px solid #00d4ff; 
    color: #fff; 
    padding: 10px; 
    margin-bottom: 10px; 
    box-sizing: border-box; 
}

#btn { 
    width: 100%; 
    padding: 10px; 
    background: #00d4ff; 
    border: none; 
    cursor: pointer; 
    font-weight: bold; 
}

.spinner { 
    width: 30px; 
    height: 30px; 
    border: 4px solid #00d4ff; 
    border-top: 4px solid #000; 
    border-radius: 50%; 
    animation: spin 1s linear infinite; 
    margin: 20px auto; 
}

@keyframes spin { 
    0% { transform: rotate(0deg); } 
    100% { transform: rotate(360deg); } 
}

.flash { 
    width: 30px; 
    height: 30px; 
    border-radius: 50%; 
    background: #00d4ff; 
    box-shadow: 0 0 20px #00d4ff; 
    margin: 20px auto; 
    animation: flash 0.5s; 
}

@keyframes flash { 
    0% { opacity: 0; } 
    50% { opacity: 1; } 
    100% { opacity: 0; } 
}

.hidden { display: none; }
